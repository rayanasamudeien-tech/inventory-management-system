generator client {
  provider = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String           @id @default(uuid())
  email           String           @unique
  password        String
  firstName       String
  lastName        String
  roleId          String
  role            Role             @relation(fields: [roleId], references: [id])
  departmentId    String?
  department      Department?      @relation(fields: [departmentId], references: [id])
  isActive        Boolean          @default(true)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  assignments     AssetAssignment[]
  transfers       AssetTransfer[]  @relation("TransferredBy")
  disposals       AssetDisposal[]
  stockTransactions StockTransaction[]
  stockAdjustments  StockAdjustment[]
  maintenanceRequests MaintenanceRequest[] @relation("Requester")
  technicianRequests   MaintenanceRequest[] @relation("Technician")
  maintenanceLogs     MaintenanceLog[]
  notifications       Notification[]
  auditLogs           AuditLog[]

  @@map("users")
}

model Role {
  id          String       @id @default(uuid())
  name        String       @unique
  description String?
  users       User[]
  permissions RolePermission[]

  @@map("roles")
}

model Permission {
  id          String           @id @default(uuid())
  name        String           @unique
  description String?
  roles       RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id])
  permission   Permission @relation(fields: [permissionId], references: [id])

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model AssetCategory {
  id          String  @id @default(uuid())
  name        String  @unique
  description String?
  assets      Asset[]

  @@map("asset_categories")
}

model Asset {
  id               String            @id @default(uuid())
  assetId          String            @unique @default(uuid()) // Auto-generated human-readable ID
  qrCode           String?           @unique
  name             String
  categoryId       String
  category         AssetCategory     @relation(fields: [categoryId], references: [id])
  subcategoryId    String?
  brand            String?
  model            String?
  serialNumber     String?           @unique
  purchaseDate     DateTime?
  purchaseCost     Float?
  supplierId       String?
  supplier         Supplier?         @relation(fields: [supplierId], references: [id])
  warrantyExpiry   DateTime?
  locationId       String?
  location         Location?         @relation(fields: [locationId], references: [id])
  departmentId     String?
  department       Department?       @relation(fields: [departmentId], references: [id])
  assignedUserId   String?
  condition        String?           // e.g., New, Good, Fair, Poor, Damaged
  status           AssetStatus       @default(FUNCTIONAL)
  photos           AssetPhoto[]
  documents        AssetDocument[]
  assignments      AssetAssignment[]
  transfers        AssetTransfer[]
  disposals        AssetDisposal[]
  maintenanceRequests MaintenanceRequest[]
  notes            String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@map("assets")
}

enum AssetStatus {
  FUNCTIONAL
  NEEDS_REPAIR
  UNDER_REPAIR
  REPAIRED
  RETIRED
  DISPOSED
}

model AssetPhoto {
  id      String @id @default(uuid())
  assetId String
  asset   Asset  @relation(fields: [assetId], references: [id])
  url     String

  @@map("asset_photos")
}

model AssetDocument {
  id      String @id @default(uuid())
  assetId String
  asset   Asset  @relation(fields: [assetId], references: [id])
  name    String
  url     String

  @@map("asset_documents")
}

model AssetAssignment {
  id         String    @id @default(uuid())
  assetId    String
  asset      Asset     @relation(fields: [assetId], references: [id])
  userId     String
  user       User      @relation(fields: [userId], references: [id])
  assignedAt DateTime  @default(now())
  returnedAt DateTime?
  status     String    @default("ACTIVE") // ACTIVE, RETURNED

  @@map("asset_assignments")
}

model AssetTransfer {
  id               String   @id @default(uuid())
  assetId          String
  asset            Asset    @relation(fields: [assetId], references: [id])
  fromLocationId   String?
  toLocationId     String
  fromDepartmentId String?
  toDepartmentId   String?
  transferredAt    DateTime @default(now())
  transferredById  String
  transferredBy    User     @relation("TransferredBy", fields: [transferredById], references: [id])
  reason           String?

  @@map("asset_transfers")
}

model AssetDisposal {
  id            String   @id @default(uuid())
  assetId       String   @unique
  asset         Asset    @relation(fields: [assetId], references: [id])
  disposedAt    DateTime @default(now())
  disposedById  String
  disposedBy    User     @relation(fields: [disposedById], references: [id])
  method        String?  // e.g., Sold, Scrapped, Donated
  reason        String?
  recoveryValue Float?

  @@map("asset_disposals")
}

model StockItem {
  id             String             @id @default(uuid())
  itemId         String             @unique @default(uuid())
  name           String
  categoryId     String
  unit           String             // e.g., kg, liters, units
  quantity       Int                @default(0)
  minThreshold   Int                @default(0)
  supplierId     String?
  supplier       Supplier?          @relation(fields: [supplierId], references: [id])
  locationId     String?
  location       Location?          @relation(fields: [locationId], references: [id])
  costPerUnit    Float?
  expiryDate     DateTime?
  transactions   StockTransaction[]
  adjustments    StockAdjustment[]
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  @@map("stock_items")
}

model StockTransaction {
  id               String          @id @default(uuid())
  stockItemId      String
  stockItem        StockItem       @relation(fields: [stockItemId], references: [id])
  type             StockTransactionType
  quantity         Int
  userId           String
  user             User            @relation(fields: [userId], references: [id])
  departmentId     String?
  department       Department?     @relation(fields: [departmentId], references: [id])
  date             DateTime        @default(now())
  reason           String?
  approvalStatus   String          @default("PENDING") // PENDING, APPROVED, REJECTED

  @@map("stock_transactions")
}

enum StockTransactionType {
  RECEIVE
  ISSUE
  RETURN
  ADJUST
}

model StockAdjustment {
  id          String    @id @default(uuid())
  stockItemId String
  stockItem   StockItem @relation(fields: [stockItemId], references: [id])
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  oldQuantity Int
  newQuantity Int
  reason      String?
  date        DateTime  @default(now())

  @@map("stock_adjustments")
}

model Location {
  id          String     @id @default(uuid())
  name        String     @unique
  description String?
  parentId    String?
  parent      Location?  @relation("LocationHierarchy", fields: [parentId], references: [id])
  children    Location[] @relation("LocationHierarchy")
  assets      Asset[]
  stockItems  StockItem[]

  @@map("locations")
}

model Department {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  users       User[]
  assets      Asset[]
  stockTransactions StockTransaction[]

  @@map("departments")
}

model Supplier {
  id            String          @id @default(uuid())
  name          String          @unique
  contactPerson String?
  phone         String?
  email         String?
  address       String?
  category      String?
  paymentTerms  String?
  assets        Asset[]
  stockItems    StockItem[]
  purchaseOrders PurchaseOrder[]

  @@map("suppliers")
}

model PurchaseOrder {
  id           String              @id @default(uuid())
  poNumber     String              @unique
  supplierId   String
  supplier     Supplier            @relation(fields: [supplierId], references: [id])
  status       String              @default("PENDING") // PENDING, SENT, RECEIVED, CANCELLED
  totalAmount  Float               @default(0)
  items        PurchaseOrderItem[]
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id           String        @id @default(uuid())
  poId         String
  purchaseOrder PurchaseOrder @relation(fields: [poId], references: [id])
  itemName     String
  quantity     Int
  unitPrice    Float
  totalPrice   Float

  @@map("purchase_order_items")
}

model MaintenanceRequest {
  id           String           @id @default(uuid())
  assetId      String
  asset        Asset            @relation(fields: [assetId], references: [id])
  requesterId  String
  requester    User             @relation("Requester", fields: [requesterId], references: [id])
  technicianId String?
  technician   User?            @relation("Technician", fields: [technicianId], references: [id])
  description  String
  priority     String           @default("MEDIUM") // LOW, MEDIUM, HIGH, URGENT
  status       String           @default("PENDING") // PENDING, ASSIGNED, IN_PROGRESS, COMPLETED, CANCELLED
  logs         MaintenanceLog[]
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@map("maintenance_requests")
}

model MaintenanceLog {
  id          String             @id @default(uuid())
  requestId   String
  request     MaintenanceRequest @relation(fields: [requestId], references: [id])
  technicianId String
  technician  User               @relation(fields: [technicianId], references: [id])
  actionTaken String
  cost        Float              @default(0)
  date        DateTime           @default(now())

  @@map("maintenance_logs")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  title     String
  message   String
  type      String   // e.g., LOW_STOCK, WARRANTY_EXPIRY, MAINTENANCE_DUE
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("notifications")
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id])
  action     String   // CREATE, UPDATE, DELETE, LOGIN, etc.
  entityName String   // Asset, User, StockItem, etc.
  entityId   String?
  oldData    Json?
  newData    Json?
  timestamp  DateTime @default(now())

  @@map("audit_logs")
}

model Setting {
  id    String @id @default(uuid())
  key   String @unique
  value String

  @@map("settings")
}
